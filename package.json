{
  "name": "@langchain/langsmith-cursor-plugins",
  "version": "0.2.0",
  "description": "Cursor hooks integration for LangSmith tracing",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && pnpm bundle",
    "bundle": "node esbuild.config.mjs",
    "dev": "tsc --watch",
    "format": "oxfmt --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "tsx": "tsx",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "install-hooks": "node scripts/install.mjs",
    "clean": "rm -rf dist bundle"
  },
  "dependencies": {
    "langsmith": "^0.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.1",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
